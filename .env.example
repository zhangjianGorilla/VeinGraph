# 脉络 (VeinGraph) 本地环境变量配置模板
# 使用方法：复制本文件为 .env，填入真实的 API 密钥。(.env 文件已被 .gitignore 忽略，不会上传到公共代码库)

# [必填] 智谱 AI (ZhiPu GLM) 开发者 API 密钥
ZHIPUAI_API_KEY=YOUR_API_KEY_HERE

# [选填] 如果你改动了 docker-compose 中的默认密码，可在此处统一覆盖应用配置
# MONGODB_PASSWORD=veingraph
# REDIS_PASSWORD=veingraph
# NEO4J_PASSWORD=veingraph
